HF_TOKEN="<your_hf_token_here>"
# Increases the read socket limit to 5 minutes so slow connections don't crash the Python initialization cycle.
HF_HUB_READ_TIMEOUT=300 
# Disables the unstable experimental Xet chunk engine, which can cause model fetches to stall or freeze indefinitely on local machines. This forces a reliable fallback to standard HTTP streaming.
HF_HUB_DISABLE_XET=1